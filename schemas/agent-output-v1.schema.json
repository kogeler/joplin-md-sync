{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kogeler/joplin-md-sync/schemas/agent-output-v1.schema.json",
  "title": "joplin-md-sync --json output envelope (v1)",
  "type": "object",
  "required": ["schema_version", "command", "success", "exit_code", "code", "tool_version", "workspace"],
  "properties": {
    "schema_version": { "const": 1 },
    "command": { "type": "string" },
    "success": {
      "type": "boolean",
      "description": "true when the command completed (exit codes 0, 1, 2, 8); false on operational errors"
    },
    "exit_code": { "type": "integer", "minimum": 0, "maximum": 9 },
    "code": {
      "type": "string",
      "description": "Machine-readable result code, e.g. OK, DIFF_FOUND, PENDING_ACTIONS, CONFLICTS_PRESENT, INVALID_WORKSPACE, INVALID_LOCAL_FILE, API_UNAVAILABLE, API_AUTH_FAILED, CONCURRENT_MODIFICATION, WORKSPACE_LOCKED, RECOVERY_REQUIRED, PARTIAL_FAILURE, UNSAFE_OPERATION_BLOCKED, VERSION_OUTDATED, UPDATE_CHECK_FAILED, UPDATE_CHECK_SKIPPED, INTERNAL_ERROR"
    },
    "tool_version": { "type": "string" },
    "workspace": { "type": ["string", "null"] },
    "error": { "type": "string" },
    "summary": {
      "type": "object",
      "properties": {
        "unchanged": { "type": "integer" },
        "local_modified": { "type": "integer" },
        "remote_modified": { "type": "integer" },
        "local_new": { "type": "integer" },
        "remote_new": { "type": "integer" },
        "local_deleted": { "type": "integer" },
        "remote_deleted": { "type": "integer" },
        "conflicts": { "type": "integer" },
        "invalid": { "type": "integer" },
        "by_status": { "type": "object", "additionalProperties": { "type": "integer" } }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": { "type": "string" },
          "note_id": { "type": ["string", "null"] },
          "folder_id": { "type": ["string", "null"] },
          "path": { "type": ["string", "null"] },
          "title": { "type": ["string", "null"] },
          "local_changed": { "type": "array", "items": { "enum": ["title", "body", "tags", "parent"] } },
          "remote_changed": { "type": "array", "items": { "enum": ["title", "body", "tags", "parent"] } },
          "detail": { "type": "string" },
          "remote_state": { "type": "string" }
        }
      }
    },
    "planned_operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["op_id", "kind"],
        "properties": {
          "op_id": { "type": "string" },
          "kind": { "type": "string" },
          "note_id": { "type": "string" },
          "folder_id": { "type": "string" },
          "path": { "type": "string" },
          "new_path": { "type": "string" },
          "fields": { "type": "array", "items": { "type": "string" } },
          "detail": { "type": "string" }
        }
      }
    },
    "execution": {
      "type": "object",
      "properties": {
        "applied": { "type": "integer" },
        "failed": { "type": "integer" },
        "skipped": { "type": "integer" },
        "conflicts_created": { "type": "integer" },
        "operations": { "type": "array" }
      }
    }
  }
}
